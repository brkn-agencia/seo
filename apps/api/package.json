{
  "name": "@seo/api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --watch src/index.ts",
    "build": "node --run build:esbuild",
    "build:esbuild": "esbuild src/index.ts --bundle --platform=node --target=node24 --outfile=dist/index.js --external:@seo/db",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@seo/db": "*",
    "@seo/config": "*",
    "express": "^5.0.0",
    "cors": "^2.8.5",
    "zod": "^4.0.0",
    "axios": "^1.7.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
